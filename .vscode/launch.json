{
  "version": "0.2.0",
  "configurations": [
    {
      "name": "super_fitness",
      "request": "launch",
      "type": "dart",
      // Feeds GROQ_API_KEY into String.fromEnvironment at build time. The file
      // is gitignored — copy env.example.json to env.json and fill it in.
      // Launching any other way leaves the key empty and the nutrition bar
      // just disappears, with no error to explain why.
      "toolArgs": ["--dart-define-from-file=env.json"]
    },
    {
      "name": "super_fitness (profile)",
      "request": "launch",
      "type": "dart",
      "flutterMode": "profile",
      "toolArgs": ["--dart-define-from-file=env.json"]
    },
    {
      "name": "super_fitness (release)",
      "request": "launch",
      "type": "dart",
      "flutterMode": "release",
      "toolArgs": ["--dart-define-from-file=env.json"]
    }
  ]
}
